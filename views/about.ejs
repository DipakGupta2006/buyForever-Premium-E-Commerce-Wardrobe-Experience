<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        About Us
    </title>
 <link rel="shortcut icon" href="images.png" type="image/x-icon">

    <link rel="stylesheet" href="/css/about.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">


    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">


    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">


</head>



<body>


    <%- include("partials/navbar") %>



    <!-- Hero Section -->


    <section class="about-hero">


        <div class="about-content">


            <p>
                Welcome to
            </p>


            <h1 style="letter-spacing: 2.6px;">
                buyForever
            </h1>


            <h2>
                Redefining your everyday fashion experience
            </h2>


            <span>
                We bring trendy, premium, and affordable fashion
                products together in one place.
            </span>


        </div>



    </section>






    <!-- About Brand -->


    <section class="about-section">


        <div class="about-box">


            <div class="about-text">


                <h1>
                    Who We Are
                </h1>


                <p>

                    buyForever is a modern fashion destination designed
                    to make online shopping simple, stylish, and reliable.

                    We carefully select products that match current
                    trends while keeping quality and affordability in mind.

                    Our goal is to provide customers with a smooth shopping
                    experience where discovering your perfect style becomes
                    effortless.

                </p>


            </div>



        </div>


    </section>







    <!-- Mission Vision -->


    <section class="mission-section">


        <div class="mission-card">


            <i class="fa-solid fa-bullseye"></i>


            <h2>
                Our Mission
            </h2>


            <p>
                To provide fashionable products with great quality,
                affordable pricing, and a seamless shopping experience.
            </p>


        </div>





        <div class="mission-card">


            <i class="fa-solid fa-eye"></i>


            <h2>
                Our Vision
            </h2>


            <p>
                To become a trusted fashion platform where customers
                find products they love and enjoy.
            </p>


        </div>



    </section>







    <!-- Why Choose Us -->


    <section class="choose-section">


        <div class="section-title">


            <p>
                buyForever
            </p>


            <h1>
                Why Choose Us?
            </h1>


        </div>




        <div class="choose-container">


            <div class="choose-card">


                <i class="fa-solid fa-shirt"></i>


                <h3>
                    Trendy Collection
                </h3>


                <span>
                    Updated fashion styles according to latest trends.
                </span>


            </div>





            <div class="choose-card">


                <i class="fa-solid fa-shield-halved"></i>


                <h3>
                    Secure Shopping
                </h3>


                <span>
                    Safe transactions and protected customer data.
                </span>


            </div>





            <div class="choose-card">


                <i class="fa-solid fa-truck-fast"></i>


                <h3>
                    Fast Delivery
                </h3>


                <span>
                    Reliable delivery service at your doorstep.
                </span>


            </div>





            <div class="choose-card">


                <i class="fa-solid fa-headset"></i>


                <h3>
                    Customer Support
                </h3>


                <span>
                    We are always ready to help you.
                </span>


            </div>



        </div>


    </section>






    <!-- CTA -->


    <section class="cta">


        <h1>
            Ready to upgrade your style?
        </h1>


        <p>
            Explore our latest collections today.
        </p>


        <a href="/collection">
            Shop Now
        </a>


    </section>


        <%- include("partials/footer") %>





</body>

</html>