<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Dashboard - add2Kart</title>

<link rel="stylesheet" href="/css/adminDashboard.css">

</head>


<body>


<div class="admin-container">


    <!-- Sidebar -->

    <aside class="sidebar">

        <div class="logo">
            add2Kart
        </div>


        <ul>

            <li class="active">
                Dashboard
            </li>

            <li>
                Products
            </li>

            <li>
                Orders
            </li>

            <li>
                Users
            </li>

            <li>
                Banners
            </li>

            <li>
                Settings
            </li>


        </ul>


        <button class="logout">
            Logout
        </button>


    </aside>





    <!-- Main Content -->

    <main class="main">


        <div class="topbar">

            <h1>
                Dashboard
            </h1>


            <div class="admin-profile">

                Admin

            </div>


        </div>





        <!-- Cards -->


        <section class="cards">


            <div class="card">

                <h3>
                    Total Users
                </h3>

                <p>
                    120
                </p>

            </div>




            <div class="card">

                <h3>
                    Total Products
                </h3>

                <p>
                    250
                </p>

            </div>





            <div class="card">

                <h3>
                    Total Orders
                </h3>

                <p>
                    80
                </p>

            </div>





            <div class="card">

                <h3>
                    Revenue
                </h3>

                <p>
                    ₹50,000
                </p>

            </div>



        </section>





        <!-- Recent Orders -->


        <section class="table-section">


            <h2>
                Recent Orders
            </h2>


            <table>


                <tr>

                    <th>
                        Order ID
                    </th>

                    <th>
                        Customer
                    </th>

                    <th>
                        Amount
                    </th>

                    <th>
                        Status
                    </th>

                </tr>



                <tr>

                    <td>
                        #101
                    </td>

                    <td>
                        Dipak
                    </td>

                    <td>
                        ₹1599
                    </td>

                    <td>
                        Delivered
                    </td>

                </tr>



                <tr>

                    <td>
                        #102
                    </td>

                    <td>
                        Rahul
                    </td>

                    <td>
                        ₹999
                    </td>

                    <td>
                        Pending
                    </td>

                </tr>


            </table>


        </section>



    </main>


</div>


</body>

</html>