<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <title>
        Contact Us
    </title>
     <link rel="shortcut icon" href="images.png" type="image/x-icon">


    <link rel="stylesheet" href="/css/contact.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/footer.css">


    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">


    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@400;500;600;700&display=swap"
        rel="stylesheet">


</head>


<body>


    <%- include("partials/navbar") %>





        <!-- Hero -->


        <section class="contact-hero">


            <div>


                <p>
                    Get In Touch With
                </p>


                <h1 style="letter-spacing: 2.6px;">
                    buyForever
                </h1>


                <span>
                    Have questions? We are always here to help you.
                </span>


            </div>


        </section>






        <!-- Contact Cards -->


        <section class="contact-info">


            <div class="info-card">


                <i class="fa-solid fa-location-dot"></i>


                <h3>
                    Our Address
                </h3>


                <p>
                    Mumbai, Maharashtra, India
                </p>


            </div>





            <div class="info-card">


                <i class="fa-solid fa-envelope"></i>


                <h3>
                    Email Us
                </h3>


                <p>
                    support@buyForever.com
                </p>


            </div>





            <div class="info-card">


                <i class="fa-solid fa-phone"></i>


                <h3>
                    Call Us
                </h3>


                <p>
                    +91 98765 43210
                </p>


            </div>





            <div class="info-card">


                <i class="fa-solid fa-clock"></i>


                <h3>
                    Working Hours
                </h3>


                <p>
                    Mon - Sat | 9 AM - 7 PM
                </p>


            </div>



        </section>







        <!-- Contact Form -->


        <section class="contact-form-section">



            <div class="form-container">



                <div class="form-title">


                    <p>
                        buyForever
                    </p>


                    <h1>
                        Send Us A Message
                    </h1>


                    <span>
                        We will get back to you as soon as possible.
                    </span>


                </div>






                <form>


                    <div class="input-group">


                        <input type="text" placeholder="Your Name" required>


                        <input type="email" placeholder="Email Address" required>


                    </div>





                    <input type="text" placeholder="Subject" required>






                    <textarea placeholder="Your Message" rows="6"></textarea>






                    <button>
                        Send Message
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>



                </form>



            </div>


        </section>

    <%- include("partials/footer") %>


</body>

</html>